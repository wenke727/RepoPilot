# RepoPilot 配置示例。复制为 .env 并按需修改。
# 后端启动时会从项目根目录加载 .env（若存在）。

# 执行模式：AGENTIC | FIXED
# REPOPILOT_EXEC_MODE=AGENTIC

# 全局驱动：CLAUDE | CLAUDE_KIMI | CLAUDE_GLM | CURSOR_CLI（预留，当前不可切换使用）
# REPOPILOT_AGENT_DRIVER=CLAUDE_KIMI
#
# KIMI/GLM 驱动默认通过 shell 模板执行（用于兼容 alias/function）。
# 默认等价：zsh -ic 'claude-kimi "$@"' repopilot ...
# REPOPILOT_AGENT_SHELL=zsh
# REPOPILOT_CLAUDE_KIMI_SHELL_TEMPLATE=claude-kimi
# REPOPILOT_CLAUDE_GLM_SHELL_TEMPLATE=claude-glm
#
# 各驱动对应可执行命令（默认值如下）
# REPOPILOT_CLAUDE_CMD=claude
# REPOPILOT_CLAUDE_KIMI_CMD=claude-kimi
# REPOPILOT_CLAUDE_GLM_CMD=claude-glm
# REPOPILOT_CURSOR_CLI_CMD=cursor

# 可选鉴权（暴露于 Tailscale/公网时建议开启）。两者都设置后鉴权才生效。
# REPOPILOT_AUTH_USERNAME=
# REPOPILOT_AUTH_PASSWORD=

# 语音输入（转写）需要。未设置时语音按钮会提示 OPENAI_API_KEY is required。
# OPENAI_API_KEY=
